# ==========================================
# 🐳 Docker Build Arguments
# (Configure in Dokploy: Configuration → Build Arguments)
# ==========================================
# Base OS version for ROCm container
UBUNTU_VERSION=24.04

# ROCm version to use for build & runtime
ROCM_VERSION=7.2.1

# AMDGPU version (typically matches ROCM_VERSION)
AMDGPU_VERSION=7.2.1

# Node.js version for UI build
NODE_VERSION=24

# ROCm GPU Architectures (semicolon-separated)
# 📌 Optimize per GPU to reduce build time & image size:
#   RX 5000 series: gfx906;gfx908
#   RX 6000 series: gfx1030;gfx1031
#   RX 7000 series: gfx1100;gfx1101;gfx1102
#   RX 8000 series: gfx1200;gfx1201
#   CDNA2/CDNA3:    gfx942;gfx940;gfx1150;gfx1151
ROCM_DOCKER_ARCH=gfx1201

# OCI Image Labels
BUILD_DATE=N/A
APP_VERSION=N/A
APP_REVISION=N/A
IMAGE_URL=https://github.com/ggml-org/llama.cpp
IMAGE_SOURCE=https://github.com/ggml-org/llama.cpp

# ==========================================
# ⚙️ Runtime & Dokploy Configuration
# (Configure in Dokploy: Configuration → Environment Variables)
# ==========================================
# Host directory to mount at /home/faks inside the container
# Leave empty to use default: /home/faks
HOST_DATA_DIR=

# Llama.cpp server bind address
# Overrides Dockerfile default (0.0.0.0). Uncomment & change if needed:
# LLAMA_ARG_HOST=0.0.0.0
